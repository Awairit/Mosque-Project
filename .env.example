# Shared
APP_ENV=production
DOMAIN=example.com

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://example.com/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-me

# Backend
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Database
POSTGRES_DB=mosque_platform
POSTGRES_USER=mosque_app
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mosque_app:replace-with-a-strong-password@postgres:5432/mosque_platform

# JWT
JWT_SIGNING_KEY=replace-with-a-separate-strong-secret
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=10
JWT_REFRESH_TOKEN_LIFETIME_DAYS=14
JWT_REFRESH_COOKIE_NAME=mosque_refresh
JWT_REFRESH_COOKIE_SECURE=true
JWT_REFRESH_COOKIE_SAMESITE=Lax

# Google
GOOGLE_MAPS_API_KEY=replace-me
