DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-local-development-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL unset for local SQLite fallback, or use PostgreSQL:
# DATABASE_URL=postgresql://mosque_app:password@localhost:5432/mosque_platform
DATABASE_URL=

DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# OTP Provider
# ---------------------------------------------------------------------------
# Use 'dummy' for local development (OTP is printed to Django console).
# Use 'twilio' in production to send real SMS via Twilio Verify.
OTP_PROVIDER=dummy

# Required only when OTP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ---------------------------------------------------------------------------
# Cloudinary Storage Configuration (Required for Production Media Storage)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

