DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-local-development-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL unset for local SQLite fallback, or use PostgreSQL:
# DATABASE_URL=postgresql://mosque_app:password@localhost:5432/mosque_platform
DATABASE_URL=postgresql://postgres:123456@localhost:5432/mosque_db

DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
